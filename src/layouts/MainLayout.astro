---
import Navbar from '../components/Navbar.astro';

const SITE_URL = 'https://brianzater.com';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Brian Zater', description } = Astro.props;

const metaDescription = description ?? 'Brian Zater — Author, advocate, and architect of redemption. Tree of Life, clemency advocacy, and structured personal growth.';
const canonicalURL = `${SITE_URL}${Astro.url.pathname}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="icon" href="/favicon.ico?v=2" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    {canonicalURL && <link rel="canonical" href={canonicalURL} />}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalURL ?? SITE_URL} />
    <meta property="og:site_name" content="Brian Zater" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <style is:global>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      html {
        font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      body {
        margin: 0;
        padding: 0;
        background-color: #f8f8f6;
        color: #111111;
        font-size: 1rem;
      }

      h1 {
        font-size: 2.25rem;
        font-weight: 700;
        letter-spacing: -0.03em;
        line-height: 1.2;
        margin: 0 0 1rem;
      }

      h2 {
        font-size: 1.5rem;
        font-weight: 600;
        letter-spacing: -0.02em;
        line-height: 1.3;
        margin: 2.5rem 0 0.75rem;
      }

      h2:first-child {
        margin-top: 0;
      }

      h3 {
        font-size: 1.125rem;
        font-weight: 600;
        margin: 1.5rem 0 0.5rem;
      }

      p {
        margin: 0 0 1rem;
        max-width: 75ch;
      }

      a {
        color: #1e3a8a;
        text-decoration: underline;
        text-underline-offset: 3px;
        text-decoration-thickness: 1px;
        transition: color 0.15s ease;
      }

      a:hover {
        color: #1e40af;
      }
    </style>
  </head>
  <body>
    <div class="layout">
      <header class="layout-header">
        <div class="layout-container">
          <Navbar />
        </div>
      </header>
      <main class="layout-main">
        <div class="layout-container">
          <slot />
        </div>
      </main>
      <footer class="site-footer">
        <div class="footer-inner">
          <span>© {new Date().getFullYear()} Brian Zater</span>
          <div class="footer-links">
            <a href="/privacy">Privacy</a>
            <a href="/terms">Terms</a>
            <a href="/disclaimer">Disclaimer</a>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>

<style>
  .layout {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .layout-header {
    flex-shrink: 0;
  }

  .layout-main {
    flex: 1;
    padding: 4rem 0 5rem;
  }

  .layout-container {
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .site-footer {
    margin-top: 5rem;
    padding: 2rem 0;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    font-size: 0.85rem;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-links a {
    text-decoration: none;
    color: #444444;
  }

  .footer-links a:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .layout-main {
      padding: 3rem 0 4rem;
    }

    .layout-container {
      padding: 0 1.25rem;
    }

    .footer-inner {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
  }
</style>
