---
import MainLayout from '../layouts/MainLayout.astro';

const AMAZON_URL = 'https://www.amazon.com/Tree-Life-Sowing-Seeds-Destiny/dp/B0GH2HSBMB/';
---

<MainLayout
  title="Tree of Life | Brian Zater"
  description="The Tree of Life: Sowing Your Seeds of Destiny by Brian Zater. A structured system for defining goals, aligning daily action with long-term vision, and building measurable progress."
>
  <!-- SECTION 1: HERO -->
  <div class="tol-hero-outer">
    <div class="tol-hero-bg" aria-hidden="true"></div>
    <div class="tol-hero-inner">
      <div class="tol-hero-content">
        <div class="tol-hero-text">
          <h1>The Tree of Life</h1>
          <p class="subtitle">Sowing Your Seeds of Destiny</p>
          <p class="lead">
            This book is for anyone ready to take ownership of their future. It provides a clear, structured system for defining goals, aligning daily action with long-term vision, and building measurable progress across every area of life.
          </p>
          <div class="tol-hero-actions">
            <a href={AMAZON_URL} target="_blank" rel="noopener noreferrer" class="tol-cta-primary">
              Purchase on Amazon
            </a>
            <a
              href="https://www.facebook.com/brianzater"
              target="_blank"
              rel="noopener noreferrer"
              class="tol-cta-secondary"
            >
              Follow on Facebook
            </a>
          </div>
        </div>
        <div class="tol-hero-image">
          <img
            src="/assets/Book Image.jpg"
            alt="Tree of Life book cover"
            width="320"
            height="480"
          />
        </div>
      </div>
    </div>
  </div>

  <!-- SECTION 2: THE FRAMEWORK -->
  <section class="tol-section">
    <h2>The Framework</h2>
    <p>
      The Tree of Life introduces a disciplined model for personal growth built around five core areas of life: Relationships, Career, Health & Fitness, Spiritual Development, and Outreach. Rather than offering abstract motivation, the book provides a structured method for setting clear targets and tracking measurable progress.
    </p>
    <h3>From Intention to Action</h3>
    <p>
      Each chapter moves beyond theory and into execution. Readers are guided through daily, weekly, monthly, quarterly, and annual goal-setting practices designed to create forward momentum. The system emphasizes accountability, clarity, and consistency — transforming aspiration into sustained action.
    </p>
  </section>

  <!-- SECTION 3: GOAL CARDS -->
  <section class="tol-section">
    <h2>Goal Cards</h2>
    <p>
      At the heart of the book is the Goal Card system — a practical tool for keeping your priorities visible and actionable. By defining goals across all five life areas and revisiting them consistently, readers reinforce direction, discipline, and intentional focus.
    </p>
    <a href="/tree-of-life/goal-cards" class="tol-button-secondary">View Printable Goal Cards</a>
  </section>

  <!-- SECTION 4: WHY IT MATTERS -->
  <section class="tol-section">
    <h2>Why It Matters</h2>
    <p>
      Long-term growth does not happen by accident. It requires structure, repetition, and personal responsibility. The Tree of Life is not a collection of inspirational ideas — it is a system designed to help individuals cultivate measurable improvement and build a life aligned with purpose.
    </p>
  </section>

</MainLayout>

<style>
  /* SECTION 1: HERO */
  .tol-hero-outer {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-bottom: 0;
    background:
      radial-gradient(circle at center, rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.9)),
      #141414;
    position: relative;
    overflow: hidden;
  }

  .tol-hero-bg {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 1200px;
    max-width: 90%;
    height: auto;
    min-height: 100%;
    background-image: url('/assets/tree_for_book_super_clean.png');
    background-size: contain;
    background-position: center;
    background-repeat: no-repeat;
    opacity: 0.1;
    z-index: 0;
    pointer-events: none;
  }

  .tol-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
    padding: 6rem 1.5rem;
  }

  .tol-hero-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .tol-hero-text {
    flex: 1;
    min-width: 280px;
    max-width: 520px;
    color: #ffffff;
  }

  .tol-hero-text h1 {
    font-size: 3.25rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin: 0 0 0.5rem;
    color: #ffffff;
  }

  .subtitle {
    font-size: 1.35rem;
    font-weight: 500;
    margin: 0 0 1rem;
    color: rgba(255, 255, 255, 0.9);
  }

  .lead {
    font-size: 1.1rem;
    line-height: 1.6;
    margin: 0 0 1.5rem;
    color: rgba(255, 255, 255, 0.9);
  }

  .tol-cta-primary {
    display: inline-block;
    padding: 0.875rem 1.75rem;
    background: #1e3a8a;
    color: #ffffff;
    text-decoration: none;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    transition: background 0.15s ease;
  }

  .tol-cta-primary:hover {
    background: #1e40af;
  }

  .tol-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
  }

  .tol-cta-secondary {
    display: inline-block;
    padding: 0.5rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.6);
    color: #ffffff;
    text-decoration: none;
    border-radius: 6px;
    font-weight: 500;
    font-size: 0.9375rem;
    transition: background 0.15s ease, border-color 0.15s ease;
  }

  .tol-cta-secondary:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.9);
  }

  .tol-hero-image {
    flex-shrink: 0;
  }

  .tol-hero-image img {
    display: block;
    width: 100%;
    max-width: 320px;
    height: auto;
    border-radius: 8px;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
  }

  /* SECTIONS 2–4 */
  .tol-section {
    margin-top: 3.5rem;
  }

  .tol-section h2 {
    margin-top: 0;
    font-size: 1.5rem;
  }

  .tol-section h3 {
    margin-top: 2rem;
    font-size: 1.125rem;
  }

  .tol-section p {
    margin: 0 0 1rem;
    max-width: 75ch;
  }

  .tol-button-secondary {
    display: inline-block;
    margin-top: 1rem;
    padding: 0.75rem 1.25rem;
    border: 1px solid #1e3a8a;
    color: #1e3a8a;
    text-decoration: none;
    border-radius: 6px;
    font-weight: 600;
    transition: background 0.15s ease, border-color 0.15s ease;
  }

  .tol-button-secondary:hover {
    background: rgba(30, 58, 138, 0.06);
    border-color: #1e40af;
  }

  @media (min-width: 768px) {
    .tol-hero-text {
      text-align: left;
    }
  }

  @media (max-width: 768px) {
    .tol-hero-inner {
      padding: 4rem 1.25rem;
    }

    .tol-hero-content {
      flex-direction: column;
      gap: 2rem;
    }

    .tol-hero-text {
      text-align: center;
    }

    .tol-hero-image {
      order: 2;
    }

    .tol-hero-image img {
      max-width: 280px;
    }

    .tol-hero-text h1 {
      font-size: 2.25rem;
    }

    .subtitle {
      font-size: 1.15rem;
    }
  }
</style>
