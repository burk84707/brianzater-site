---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="Terms of Use | Brian Zater"
  description="Terms of use for brianzater.com. Content use, intellectual property, external links, and limitation of liability."
>
  <h1>Terms of Use</h1>

  <section class="legal-section">
    <h2>Use of Content</h2>
    <p>
      Content on this site is provided for informational purposes only. It does not
      constitute legal advice. No attorney-client relationship is formed by visiting
      or using this site.
    </p>
  </section>

  <section class="legal-section">
    <h2>Intellectual Property</h2>
    <p>
      All original content belongs to Brian Zater unless otherwise stated.
    </p>
  </section>

  <section class="legal-section">
    <h2>External Links</h2>
    <p>
      This site is not responsible for the content or practices of third-party sites
      linked from this site.
    </p>
  </section>

  <section class="legal-section">
    <h2>Limitation of Liability</h2>
    <p>
      Use of this site is at your own discretion. The site owner is not liable for any
      damages arising from use of this site or its content.
    </p>
  </section>
</MainLayout>

<style>
  .legal-section {
    margin-top: 2rem;
  }

  .legal-section h2 {
    margin-top: 0;
  }
</style>
