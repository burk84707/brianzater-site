---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="Brian Zater"
  description="Brian Zater — Author, advocate, architect of redemption. Tree of Life book, clemency petition, and structured personal growth. Explore his work and advocacy."
>

  <!-- 1. HERO — Split Editorial Layout -->
  <section class="hero-split">
    <div class="hero-split-content">
      <div class="hero-split-text">
        <h1>Brian Zater</h1>
        <p class="hero-subtitle">Author. Advocate. Architect of Redemption.</p>
        <p class="hero-description">
          A forward-looking voice focused on transformation, responsibility, and measurable impact.
          This platform documents Brian's work, advocacy initiatives, and formal clemency petition.
        </p>
        <div class="hero-actions">
          <a href="/clemency" class="button-primary">Clemency Overview</a>
          <a href="/tree-of-life" class="button-secondary">Tree of Life</a>
        </div>
      </div>
      <div class="hero-split-image">
        <img
          src="/assets/Brian Zater.png"
          alt="Brian Zater"
          width="480"
          height="480"
        />
      </div>
    </div>
  </section>

  <!-- 2. TREE OF LIFE FEATURE — Split Layout -->
  <section class="section tree-feature">
    <div class="tree-feature-content">
      <div class="tree-feature-image">
        <img
          src="/assets/Book Image.jpg"
          alt="Tree of Life book cover"
          width="320"
          height="480"
        />
      </div>
      <div class="tree-feature-text">
        <h2>Tree of Life</h2>
        <p class="tree-subtitle">Sowing Your Seeds of Destiny</p>
        <p>
          Tree of Life is a structured reflection framework designed to help readers
          examine personal responsibility, growth, and long-term intention. The book
          provides practical tools for aligning daily actions with broader purpose
          and measurable outcomes.
        </p>
        <a href="/tree-of-life" class="button-primary">Explore the Book</a>
      </div>
    </div>
  </section>

  <!-- 3. CLEMENCY FEATURE -->
  <section class="section clemency-feature">
    <h2>Clemency</h2>
    <p>
      The formal clemency petition outlines the legal foundation, personal development,
      institutional record, and community support surrounding this request.
    </p>
    <a href="/clemency" class="button-primary">View Petition</a>
  </section>

  <!-- 4. FINAL CTA STRIP -->
  <section class="cta-strip">
    <p class="cta-strip-statement">
      Structured growth. Accountable leadership. Measurable impact.
    </p>
    <a href="/clemency" class="button-primary">Read the Clemency Petition</a>
  </section>

</MainLayout>

<style>
  /* 1. HERO — Split Editorial Layout */
  .hero-split {
    padding: 5rem 0 6rem;
  }

  .hero-split-content {
    display: flex;
    align-items: center;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .hero-split-text {
    flex: 1;
    min-width: 280px;
    max-width: 520px;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    font-weight: 500;
    margin-bottom: 1rem;
  }

  .hero-description {
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-split-image {
    flex-shrink: 0;
  }

  .hero-split-image img {
    display: block;
    width: 100%;
    max-width: 460px;
    height: auto;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 10px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  /* 2. TREE OF LIFE FEATURE — Split Layout */
  .section {
    margin-top: 3.5rem;
  }

  .tree-feature-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .tree-feature-image {
    flex-shrink: 0;
  }

  .tree-feature-image img {
    display: block;
    width: 100%;
    max-width: 320px;
    height: auto;
    border-radius: 8px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
  }

  .tree-feature-text {
    flex: 1;
    min-width: 280px;
  }

  .tree-feature-text h2 {
    margin-top: 0;
  }

  .tree-subtitle {
    font-size: 1.15rem;
    font-weight: 500;
    margin: 0 0 1rem;
    color: #333333;
  }

  .tree-feature-text p {
    margin-bottom: 1.5rem;
  }

  /* 3. CLEMENCY FEATURE */
  .clemency-feature {
    text-align: center;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .clemency-feature h2 {
    margin-top: 0;
  }

  .clemency-feature p {
    margin-left: auto;
    margin-right: auto;
  }

  /* 4. FINAL CTA STRIP */
  .cta-strip {
    margin-top: 4rem;
    padding: 4rem 1.5rem;
    background: rgba(30, 58, 138, 0.04);
    text-align: center;
    border-radius: 8px;
  }

  .cta-strip-statement {
    font-size: 1.25rem;
    font-weight: 500;
    margin: 0 0 1.5rem;
    color: #111111;
  }

  /* Buttons */
  .button-primary {
    display: inline-block;
    padding: 0.75rem 1.25rem;
    background: #1e3a8a;
    color: #ffffff;
    text-decoration: none;
    border-radius: 6px;
    font-weight: 600;
  }

  .button-primary:hover {
    background: #1e40af;
  }

  .button-secondary {
    display: inline-block;
    padding: 0.75rem 1.25rem;
    border: 1px solid #1e3a8a;
    color: #1e3a8a;
    text-decoration: none;
    border-radius: 6px;
    font-weight: 600;
  }

  .button-secondary:hover {
    background: rgba(30, 58, 138, 0.06);
  }

  @media (max-width: 768px) {
    .hero-split {
      padding: 4rem 0 5rem;
    }

    .hero-split-content {
      flex-direction: column;
      gap: 2rem;
    }

    .hero-split-text {
      text-align: center;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-split-image {
      order: 2;
    }

    .hero-split-image img {
      max-width: 320px;
    }

    .tree-feature-content {
      flex-direction: column;
    }

    .tree-feature-image {
      order: 1;
    }

    .tree-feature-text {
      order: 2;
    }
  }
</style>
