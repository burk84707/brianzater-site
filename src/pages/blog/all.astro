---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<MainLayout
  title="All Posts | Brian Zater"
  description="Complete archive of Roots of Reform blog posts. Brian Zater's writing on accountability, reform, and structured thinking."
>
  <div class="blog-page">
    <h1>All Posts</h1>
    <p class="blog-intro">Complete archive of blog entries.</p>

    <ul class="post-list">
      {posts.map((post) => (
        <li class="post-item">
          <a href={`/blog/${post.id}`} class="post-title">{post.data.title}</a>
          <time class="post-date" datetime={post.data.date.toISOString()}>
            {formatDate(post.data.date)}
          </time>
          <p class="post-description">{post.data.description}</p>
        </li>
      ))}
    </ul>
  </div>
</MainLayout>

<style>
  .blog-page {
    max-width: 800px;
  }

  .blog-page h1 {
    margin-top: 0;
  }

  .blog-intro {
    margin-bottom: 2rem;
    color: #555555;
  }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-item {
    padding: 1.5rem 0;
    border-bottom: 1px solid rgba(30, 58, 138, 0.12);
  }

  .post-item:last-of-type {
    border-bottom: none;
  }

  .post-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: #111111;
    text-decoration: none;
    display: block;
    margin-bottom: 0.25rem;
  }

  .post-title:hover {
    color: #1e3a8a;
  }

  .post-date {
    font-size: 0.875rem;
    color: #555555;
    margin-bottom: 0.5rem;
    display: block;
  }

  .post-description {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: #333333;
  }
</style>
