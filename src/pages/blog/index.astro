---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<MainLayout
  title="Roots of Reform | Brian Zater"
  description="Roots of Reform — Thoughts on accountability, reform, and the architecture of change. Brian Zater's blog on disciplined personal growth and justice reform."
>
  <div class="blog-page">
    <section class="blog-hero">
      <h1>Roots of Reform</h1>
      <p class="blog-subtitle">
        Thoughts on Accountability, Reform, and the Architecture of Change
      </p>
    </section>

    <p class="blog-intro">
      Roots explores disciplined personal growth, justice reform, and structured thinking. Each entry reflects on responsibility, institutional change, and the systems that shape individual and collective outcomes.
    </p>

    <ul class="post-list">
      {posts.map((post) => (
        <li class="post-item">
          <a href={`/blog/${post.id}`} class="post-title">{post.data.title}</a>
          <time class="post-date" datetime={post.data.date.toISOString()}>
            {formatDate(post.data.date)}
          </time>
          <p class="post-description">{post.data.description}</p>
        </li>
      ))}
    </ul>

    <div class="blog-actions">
      <a href="/blog/all" class="button-secondary">View All Posts</a>
    </div>
  </div>
</MainLayout>

<style>
  .blog-page {
    max-width: 800px;
  }

  .blog-hero {
    margin-bottom: 3.5rem;
    max-width: 900px;
  }

  .blog-hero h1 {
    font-size: 2.6rem;
    margin: 0 0 0.5rem;
  }

  .blog-subtitle {
    font-size: 1.1rem;
    opacity: 0.7;
    margin: 0;
    max-width: 700px;
  }

  .blog-intro {
    margin-top: 1.5rem;
    margin-bottom: 2.5rem;
    line-height: 1.7;
    max-width: 800px;
  }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-item {
    padding: 1.5rem 0;
    border-bottom: 1px solid rgba(30, 58, 138, 0.12);
  }

  .post-item:last-of-type {
    border-bottom: none;
  }

  .post-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: #111111;
    text-decoration: none;
    display: block;
    margin-bottom: 0.25rem;
  }

  .post-title:hover {
    color: #1e3a8a;
  }

  .post-date {
    font-size: 0.875rem;
    color: #555555;
    margin-bottom: 0.5rem;
    display: block;
  }

  .post-description {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: #333333;
  }

  .blog-actions {
    margin-top: 2.5rem;
  }

  .button-secondary {
    display: inline-block;
    padding: 0.75rem 1.25rem;
    border: 1px solid #1e3a8a;
    color: #1e3a8a;
    text-decoration: none;
    border-radius: 6px;
    font-weight: 600;
  }

  .button-secondary:hover {
    background: rgba(30, 58, 138, 0.06);
  }
</style>
