---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="Privacy Policy | Brian Zater"
  description="Privacy policy for brianzater.com. Information collection, use, cookies, and third-party links."
>
  <h1>Privacy Policy</h1>

  <section class="legal-section">
    <h2>Information Collection</h2>
    <p>
      This site does not directly collect personal data from visitors. Third-party services
      (including Amazon, Google Forms, Change.org, and the hosting provider) may collect
      data according to their own policies when you interact with links or embedded content
      on this site.
    </p>
  </section>

  <section class="legal-section">
    <h2>Use of Information</h2>
    <p>
      No personal information is sold or shared with third parties for marketing purposes.
    </p>
  </section>

  <section class="legal-section">
    <h2>Cookies</h2>
    <p>
      This site does not use tracking cookies beyond standard hosting functionality. If
      analytics or other tracking tools are added in the future, this policy may be updated.
    </p>
  </section>

  <section class="legal-section">
    <h2>Third-Party Links</h2>
    <p>
      External links to other websites are governed by their own privacy policies. This site
      is not responsible for the practices of third-party sites.
    </p>
  </section>

  <section class="legal-section">
    <h2>Contact</h2>
    <p>
      For privacy-related inquiries, please use the contact information provided on the site.
    </p>
  </section>
</MainLayout>

<style>
  .legal-section {
    margin-top: 2rem;
  }

  .legal-section h2 {
    margin-top: 0;
  }
</style>
