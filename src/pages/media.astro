---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Media | Brian Zater">
  <h1>Media</h1>

  <p>
    Interviews, discussions, and public-facing material related to Brian's work,
    advocacy, and clemency petition.
  </p>

  <div class="video-wrapper">
    <iframe
      src="https://www.youtube.com/embed/oV3coDroCHQ"
      title="Brian Zater Interview"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
    ></iframe>
  </div>
</MainLayout>

<style>
  .video-wrapper {
    margin-top: 2rem;
    position: relative;
    width: 100%;
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
    padding-bottom: 56.25%;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid rgba(30, 58, 138, 0.15);
  }

  .video-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
