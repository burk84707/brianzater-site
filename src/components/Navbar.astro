---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/tree-of-life', label: 'Tree of Life' },
  { href: '/projects', label: 'Projects' },
  { href: '/media', label: 'Media' },
  { href: '/blog', label: 'Blog' },
];
---

<nav class="navbar">
  <a href="/" class="navbar-brand">Brian Zater</a>
  <button
    class="navbar-toggle"
    type="button"
    aria-label="Toggle navigation"
    aria-expanded="false"
    onclick="toggleNavbar(this)"
  >
    <span class="navbar-toggle-icon"></span>
    <span class="navbar-toggle-icon"></span>
    <span class="navbar-toggle-icon"></span>
  </button>
  <ul class="navbar-links">
    {navLinks.map((link) => (
      <li>
        <a href={link.href} class={`navbar-link ${Astro.url.pathname === link.href ? 'is-active' : ''}`}>{link.label}</a>
      </li>
    ))}
  </ul>
</nav>

<script is:inline>
  function toggleNavbar(btn) {
    const links = btn.nextElementSibling;
    if (links) {
      links.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', links.classList.contains('is-open'));
    }
  }
</script>

<style>
  .navbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid rgba(30, 58, 138, 0.12);
  }

  .navbar-brand {
    font-size: 1.5rem;
    font-weight: 700;
    color: #111111;
    text-decoration: none;
    letter-spacing: -0.03em;
    transition: color 0.15s ease;
  }

  .navbar-brand:hover {
    color: #1e3a8a;
  }

  .navbar-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 0.5rem;
    background: transparent;
    border: 1px solid rgba(30, 58, 138, 0.2);
    border-radius: 4px;
    cursor: pointer;
  }

  .navbar-toggle-icon {
    display: block;
    width: 20px;
    height: 2px;
    background: #111111;
    border-radius: 1px;
  }

  .navbar-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 2.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .navbar-link {
    color: #111111;
    text-decoration: none;
    font-size: 0.95rem;
    letter-spacing: 0.01em;
    padding: 0.375rem 0;
    border-radius: 4px;
    transition: color 0.15s ease, opacity 0.15s ease;
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
  }

  .navbar-link:hover {
    color: #1e3a8a;
    text-decoration: underline;
    opacity: 0.85;
  }

  .navbar-link.is-active {
    color: #1e3a8a;
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .navbar-toggle {
      display: flex;
    }

    .navbar-links {
      display: none;
      flex-basis: 100%;
      flex-direction: column;
      align-items: stretch;
      padding-top: 1.25rem;
      gap: 0.25rem;
    }

    .navbar-links.is-open {
      display: flex;
    }

    .navbar-link {
      padding: 0.75rem 0.5rem;
    }
  }
</style>
