---
const PETITION_URL =
  'https://www.change.org/p/support-brian-zater-s-sentence-reduction-a-case-for-redemption-and-rehabilitation';
const FORM_URL =
  'https://docs.google.com/forms/d/e/1FAIpQLScdPUG8dRJba5v4N59ryfXcit_9mtqa1sIRyIYf0b8n0fkxDw/viewform?usp=header';
---

<section class="petition-section">
  <div class="petition-content">
    <div class="petition-left">
      <div class="petition-image">
        <!-- Replace with <img src="/clemency-petition.jpg" alt="Clemency petition" /> when image is available -->
        <div class="petition-image-placeholder" aria-hidden="true"></div>
      </div>
      <div class="petition-summary">
        <h3>Petition Summary</h3>
        <p>
          This petition requests a sentence reduction based on demonstrated rehabilitation,
          institutional conduct, and a documented record of constructive contribution.
        </p>
        <p>
          The formal petition outlines the legal basis, personal development over two decades,
          and community support for this request. Supporting materials include character
          references, program participation records, and written work.
        </p>
        <p>
          Public support helps demonstrate the breadth of belief in second chances and
          evidence-based sentencing reform.
        </p>
      </div>
    </div>
    <aside class="petition-sidebar">
      <div class="signature-card">
        <h3>Support the Petition</h3>
        <div class="signature-stats">
          <span class="signature-count" data-count>124</span>
          <span class="signature-label">signatures</span>
        </div>
        <div class="progress-bar">
          <div class="progress-fill" data-progress style="width: 62%"></div>
        </div>
        <p class="progress-label" data-progress-label>62% of 200 goal</p>
        <p class="last-updated" data-timestamp hidden></p>
        <button type="button" class="button-check" data-check-btn>
          Check Live Signature Count
        </button>
        <p class="fetch-error" data-fetch-error hidden>
          Live count unavailable. Please visit Change.org for current total.
        </p>
        <a href={PETITION_URL} target="_blank" rel="noopener noreferrer" class="button-primary">
          Sign the Petition
        </a>
        <a href={FORM_URL} target="_blank" rel="noopener noreferrer" class="button-secondary">
          Provide a Formal Statement of Support
        </a>
      </div>
    </aside>
  </div>
</section>

<script is:inline>
  (function () {
    const root = document.currentScript.closest('section');
    if (!root) return;

    const countEl = root.querySelector('[data-count]');
    const progressEl = root.querySelector('[data-progress]');
    const progressLabelEl = root.querySelector('[data-progress-label]');
    const timestampEl = root.querySelector('[data-timestamp]');
    const checkBtn = root.querySelector('[data-check-btn]');
    const fetchErrorEl = root.querySelector('[data-fetch-error]');

    if (!checkBtn || !countEl || !progressEl || !progressLabelEl) return;

    checkBtn.addEventListener('click', function () {
      checkBtn.disabled = true;
      checkBtn.textContent = 'Checking...';

      fetch('/petition-count')
        .then(function (res) {
          if (!res.ok) throw new Error('API error');
          return res.json();
        })
        .then(function (data) {
          countEl.textContent = data.count.toLocaleString();
          progressEl.style.width = data.percentComplete + '%';
          progressLabelEl.textContent =
            data.percentComplete + '% of ' + data.goal.toLocaleString() + ' goal';
          if (data.lastUpdated) {
            timestampEl.hidden = false;
            timestampEl.textContent = 'Updated ' + new Date(data.lastUpdated).toLocaleString();
          }
          checkBtn.textContent = 'Live count loaded';
        })
        .catch(function () {
          fetchErrorEl.hidden = false;
          checkBtn.textContent = 'Check Live Signature Count';
          checkBtn.disabled = false;
        });
    });
  })();
</script>

<style>
  .petition-section {
    margin-top: 4rem;
  }

  .petition-content {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 3rem;
    align-items: start;
  }

  .petition-left {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .petition-image {
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid rgba(30, 58, 138, 0.12);
    background: #ffffff;
  }

  .petition-image img,
  .petition-image-placeholder {
    display: block;
    width: 100%;
    height: auto;
    min-height: 200px;
    object-fit: cover;
  }

  .petition-image-placeholder {
    background: rgba(30, 58, 138, 0.06);
  }

  .petition-summary h3 {
    margin-top: 0;
  }

  .petition-summary p {
    max-width: 75ch;
  }

  .petition-sidebar {
    position: sticky;
    top: 2rem;
  }

  .signature-card {
    padding: 1.75rem;
    border: 1px solid rgba(30, 58, 138, 0.12);
    border-radius: 10px;
    background: #ffffff;
  }

  .signature-card h3 {
    margin-top: 0;
    margin-bottom: 1rem;
  }

  .signature-stats {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .signature-count {
    font-size: 2.25rem;
    font-weight: 700;
    color: #111111;
    letter-spacing: -0.02em;
  }

  .signature-label {
    font-size: 0.9375rem;
    color: #555555;
  }

  .progress-bar {
    height: 8px;
    background: rgba(30, 58, 138, 0.12);
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 0.5rem;
  }

  .progress-fill {
    height: 100%;
    background: #1e3a8a;
    border-radius: 4px;
    transition: width 0.4s ease;
  }

  .progress-label {
    font-size: 0.875rem;
    color: #555555;
    margin: 0 0 0.25rem;
  }

  .last-updated {
    font-size: 0.75rem;
    color: #777777;
    margin: 0 0 1rem;
  }

  .button-check {
    display: block;
    width: 100%;
    padding: 0.5rem 0.75rem;
    margin-bottom: 1rem;
    font-size: 0.875rem;
    background: transparent;
    border: 1px solid rgba(30, 58, 138, 0.3);
    color: #1e3a8a;
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease;
  }

  .button-check:hover:not(:disabled) {
    background: rgba(30, 58, 138, 0.06);
    border-color: rgba(30, 58, 138, 0.5);
  }

  .button-check:disabled {
    cursor: default;
    opacity: 0.7;
  }

  .fetch-error {
    font-size: 0.875rem;
    color: #555555;
    margin: 0 0 1rem;
  }

  .signature-card .button-primary {
    display: block;
    width: 100%;
    padding: 0.75rem 1.25rem;
    margin-bottom: 0.75rem;
    background: #1e3a8a;
    color: #ffffff;
    text-decoration: none;
    border-radius: 6px;
    font-weight: 600;
    text-align: center;
    border: none;
    transition: background 0.15s ease;
  }

  .signature-card .button-primary:hover {
    background: #1e40af;
  }

  .signature-card .button-secondary {
    display: block;
    width: 100%;
    padding: 0.625rem 1rem;
    border: 1px solid rgba(30, 58, 138, 0.3);
    color: #1e3a8a;
    text-decoration: none;
    border-radius: 6px;
    font-weight: 500;
    text-align: center;
    font-size: 0.9375rem;
    transition: background 0.15s ease, border-color 0.15s ease;
  }

  .signature-card .button-secondary:hover {
    background: rgba(30, 58, 138, 0.06);
    border-color: rgba(30, 58, 138, 0.5);
  }

  @media (max-width: 900px) {
    .petition-content {
      grid-template-columns: 1fr;
    }

    .petition-sidebar {
      position: static;
    }
  }
</style>
